{
  "name": "folea",
  "version": "0.0.0",
  "description": "Keyboard-driven minimalist note manager for Typst notes.",
  "main": "out/main/index.js",
  "private": true,
  "license": "Apache-2.0",
  "desktopName": "folea",
  "author": {
    "name": "folea contributors",
    "email": "maintainers@folea.dev"
  },
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "packageManager": "npm@11.12.1",
  "build": {
    "appId": "dev.folea.app",
    "productName": "folea",
    "copyright": "Copyright © 2026 folea contributors",
    "files": [
      "out/**",
      "assets/brand/folea-icon.svg",
      "package.json",
      "LICENSE",
      "NOTICE"
    ],
    "asarUnpack": [
      "node_modules/@vscode/ripgrep-*/bin/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/brand/folea-icon.svg"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/brand/folea-icon.svg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/brand/folea-icon.svg",
      "category": "Utility",
      "maintainer": "folea contributors <maintainers@folea.dev>",
      "syncDesktopName": true
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && electron-builder --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "package:linux:appimage": "npm run build && electron-builder --linux AppImage --publish never",
    "package:all": "npm run build && electron-builder --linux AppImage deb --win nsis --mac dmg --publish never",
    "app:install": "npm run package:dir && node scripts/install-unpacked.mjs",
    "app:uninstall": "node scripts/uninstall-unpacked.mjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "typecheck:parity": "node node_modules/typescript/bin/tsc -p tsconfig.node.json --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"*.config.ts\"",
    "lint:type-aware": "eslint --config eslint.typed.config.mjs \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit:changed": "vitest run --changed",
    "test:unit:related": "vitest related --run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:run": "playwright test",
    "rebuild": "electron-builder install-app-deps",
    "measure:cold-start": "npm run build && node scripts/measure-cold-start.mjs",
    "measure:warm-open": "npm run build && node scripts/measure-warm-open.mjs",
    "measure:input-next-frame": "npm run build && node scripts/measure-input-to-paint.mjs",
    "measure:input-to-paint": "npm run measure:input-next-frame",
    "measure:graph-delta": "npm run build && node scripts/measure-graph-build.mjs",
    "measure:graph-build": "npm run measure:graph-delta",
    "measure:baselines": "npm run build && node scripts/measure-cold-start.mjs && node scripts/measure-warm-open.mjs && node scripts/measure-input-to-paint.mjs && node scripts/measure-graph-build.mjs",
    "measure:check": "node scripts/check-performance-results.mjs"
  },
  "dependencies": {
    "@myriaddreamin/typst-ts-renderer": "0.7.0",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0",
    "@vscode/ripgrep": "^1.18.0",
    "chokidar": "^5.0.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
